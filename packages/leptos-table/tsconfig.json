{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "declaration": true,
        "declarationDir": "./dist",
        "outDir": "./dist",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "lib": [
            "ES2020",
            "DOM"
        ]
    },
    "include": [
        "next/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}